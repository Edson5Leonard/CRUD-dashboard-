<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body {
            background-color: #f8f9fc;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .grafico-container {
            background: white;
            border-radius: 10px;
            padding: 15px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            margin-bottom: 20px;
        }
        .chart-box {
            position: relative;
            height: 200px;
            width: 100%;
        }
        .table-container {
            background: white;
            border-radius: 10px;
            padding: 20px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }
    </style>
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="/dashboard">
                <i class="bi bi-people-fill"></i> CRUD Empleados
            </a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="/empleados">Lista</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/empleados/nuevo">Nuevo</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container">
        <h1 class="mb-4">
            <i class="bi bi-list-ul"></i> Lista de Empleados
        </h1>
        
        <!-- DOS GRÁFICOS EN LA MISMA PÁGINA -->
        <div class="row mb-4">
            <!-- Gráfico 1: Empleados por Área (Circular) -->
            <div class="col-md-6">
                <div class="grafico-container">
                    <h5 class="text-center mb-3">
                        <i class="bi bi-pie-chart text-primary"></i> Empleados por Área
                    </h5>
                    <div class="chart-box">
                        <canvas id="graficoAreas"></canvas>
                    </div>
                    <div class="row mt-3 text-center">
                        <% if (graficoAreas && graficoAreas.length > 0) { %>
                            <% graficoAreas.forEach(area => { %>
                                <div class="col-4">
                                    <small><%= area.label %></small>
                                    <br>
                                    <strong><%= area.value %></strong>
                                </div>
                            <% }); %>
                        <% } %>
                    </div>
                </div>
            </div>
            <!-- Gráfico 2: Empleados por Categoría (Barras) -->
            <div class="col-md-6">
                <div class="grafico-container">
                    <h5 class="text-center mb-3">
                        <i class="bi bi-bar-chart text-success"></i> Empleados por Categoría
                    </h5>
                    <div class="chart-box">
                        <canvas id="graficoCategorias"></canvas>
                    </div>
                    <div class="row mt-3 text-center">
                        <% if (graficoCategorias && graficoCategorias.length > 0) { %>
                            <% graficoCategorias.forEach(cat => { %>
                                <div class="col-4">
                                    <small><%= cat.label %></small>
                                    <br>
                                    <strong><%= cat.value %></strong>
                                </div>
                            <% }); %>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Botón nuevo empleado -->
        <a href="/empleados/nuevo" class="btn btn-success mb-3">
            <i class="bi bi-person-plus"></i> Nuevo Empleado
        </a>

        <!-- Filtros -->
        <div class="card mb-4">
            <div class="card-body">
                <form method="GET" class="row g-3">
                    <div class="col-md-4">
                        <input type="text" name="nombre" class="form-control" placeholder="Buscar por nombre" value="<%= filtros.nombre %>">
                    </div>
                    <div class="col-md-3">
                        <select name="tipo_id" class="form-select">
                            <option value="">Todos los tipos</option>
                            <option value="1" <%= filtros.tipo_id == 1 ? 'selected' : '' %>>Administrativo</option>
                            <option value="2" <%= filtros.tipo_id == 2 ? 'selected' : '' %>>Operativo</option>
                            <option value="3" <%= filtros.tipo_id == 3 ? 'selected' : '' %>>Supervisor</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <select name="area_id" class="form-select">
                            <option value="">Todas las áreas</option>
                            <option value="1" <%= filtros.area_id == 1 ? 'selected' : '' %>>Sistemas</option>
                            <option value="2" <%= filtros.area_id == 2 ? 'selected' : '' %>>RRHH</option>
                            <option value="3" <%= filtros.area_id == 3 ? 'selected' : '' %>>Logística</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100">Filtrar</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Tabla de empleados -->
        <div class="table-container">
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Email</th>
                        <th>Salario</th>
                        <th>Tipo</th>
                        <th>Área</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% empleados.forEach(emp => { %>
                    <tr>
                        <td><%= emp.id %></td>
                        <td><%= emp.nombre %></td>
                        <td><%= emp.email %></td>
                        <td>S/. <%= Number(emp.salario).toFixed(2) %></td>
                        <td><%= emp.tipo %></td>
                        <td><%= emp.area %></td>
                        <td>
                            <a href="/empleados/<%= emp.id %>/editar" class="btn btn-sm btn-warning">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form action="/empleados/<%= emp.id %>/eliminar" method="POST" style="display:inline;">
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('¿Eliminar?')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Gráfico de Áreas (Circular)
        const ctxAreas = document.getElementById('graficoAreas').getContext('2d');
        new Chart(ctxAreas, {
            type: 'pie',
            data: {
                labels: [<% graficoAreas.forEach(item => { %>'<%= item.label %>', <% }); %>],
                datasets: [{
                    data: [<% graficoAreas.forEach(item => { %><%= item.value %>, <% }); %>],
                    backgroundColor: ['#4e73df', '#1cc88a', '#f6c23e', '#36b9cc', '#e74a3b'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                }
            }
        });

        // Gráfico de Categorías (Barras)
        const ctxCategorias = document.getElementById('graficoCategorias').getContext('2d');
        new Chart(ctxCategorias, {
            type: 'bar',
            data: {
                labels: [<% graficoCategorias.forEach(item => { %>'<%= item.label %>', <% }); %>],
                datasets: [{
                    label: 'Cantidad',
                    data: [<% graficoCategorias.forEach(item => { %><%= item.value %>, <% }); %>],
                    backgroundColor: '#1cc88a',
                    borderRadius: 5
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: { 
                        beginAtZero: true, 
                        stepSize: 1,
                        grid: { display: false }
                    }
                },
                plugins: {
                    legend: { display: false }
                }
            }
        });
    </script>
</body>
</html>