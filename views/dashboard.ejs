<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body {
            background-color: #f8f9fc;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .dashboard-container {
            padding: 20px;
        }
        .stat-card {
            background: white;
            border-radius: 15px;
            padding: 20px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            transition: transform 0.3s;
            border-left: 5px solid;
            margin-bottom: 20px;
        }
        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 6px 12px rgba(0,0,0,0.1);
        }
        .stat-icon {
            font-size: 2.5rem;
            color: #4e73df;
        }
        .stat-label {
            color: #b0b0b0;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .stat-number {
            font-size: 2rem;
            font-weight: bold;
            margin: 5px 0;
        }
        .card-dashboard {
            background: white;
            border-radius: 15px;
            padding: 20px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            margin-bottom: 20px;
        }
        .card-title {
            color: #4e73df;
            font-size: 1.2rem;
            font-weight: bold;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid #e3e6f0;
        }
        .ultimo-registro {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }
        .ultimo-registro .stat-label {
            color: rgba(255,255,255,0.8);
        }
        .chart-container {
            position: relative;
            height: 300px;
            width: 100%;
            margin: 20px 0;
        }
        .badge-estado {
            padding: 8px 15px;
            border-radius: 20px;
            font-weight: normal;
        }
        .progress {
            height: 10px;
            border-radius: 5px;
            margin: 10px 0;
        }
    </style>
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/dashboard">
                <i class="bi bi-grid-3x3-gap-fill"></i> Dashboard Empleados
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link active" href="/dashboard">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/empleados">
                            <i class="bi bi-people"></i> Empleados
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/empleados/nuevo">
                            <i class="bi bi-person-plus"></i> Nuevo
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container dashboard-container">
        <!-- Título -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1><i class="bi bi-speedometer2"></i> Dashboard</h1>
            <span class="badge bg-primary p-3">
                <i class="bi bi-people"></i> Total: <strong><%= totalRegistros %></strong> empleados
            </span>
        </div>

        <!-- Fila 1: Tarjetas de resumen -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="stat-card" style="border-left-color: #4e73df;">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="stat-label">Total Empleados</div>
                            <div class="stat-number"><%= totalRegistros %></div>
                            <small>Registros activos</small>
                        </div>
                        <div class="stat-icon">
                            <i class="bi bi-people-fill" style="color: #4e73df;"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card" style="border-left-color: #1cc88a;">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="stat-label">Estados</div>
                            <div class="stat-number"><%= estados.length %></div>
                            <small>Tipos diferentes</small>
                        </div>
                        <div class="stat-icon">
                            <i class="bi bi-tags-fill" style="color: #1cc88a;"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card" style="border-left-color: #f6c23e;">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="stat-label">Áreas</div>
                            <div class="stat-number"><%= graficoAreas.length %></div>
                            <small>Departamentos</small>
                        </div>
                        <div class="stat-icon">
                            <i class="bi bi-diagram-3-fill" style="color: #f6c23e;"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card" style="border-left-color: #e74a3b;">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="stat-label">Categorías</div>
                            <div class="stat-number"><%= graficoCategorias.length %></div>
                            <small>Niveles</small>
                        </div>
                        <div class="stat-icon">
                            <i class="bi bi-bar-chart-fill" style="color: #e74a3b;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Fila 2: Últimos registros -->
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="card-dashboard ultimo-registro">
                    <h5><i class="bi bi-plus-circle-fill"></i> Último Empleado Insertado</h5>
                    <div class="row">
                        <div class="col-8">
                            <h3><%= ultimoInsertado.nombre %></h3>
                            <p><i class="bi bi-envelope"></i> <%= ultimoInsertado.email %></p>
                            <p><i class="bi bi-tag"></i> <%= ultimoInsertado.categoria %></p>
                            <p><i class="bi bi-calendar"></i> <%= ultimoInsertado.fecha %></p>
                        </div>
                        <div class="col-4 text-end">
                            <i class="bi bi-person-badge" style="font-size: 5rem; opacity: 0.3;"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card-dashboard" style="background: linear-gradient(135deg, #36b9cc 0%, #1a8fe3 100%); color: white;">
                    <h5><i class="bi bi-pencil-square"></i> Último Empleado Actualizado</h5>
                    <div class="row">
                        <div class="col-8">
                            <h3><%= ultimoActualizado.nombre %></h3>
                            <p><i class="bi bi-envelope"></i> <%= ultimoActualizado.email %></p>
                            <p><i class="bi bi-tag"></i> <%= ultimoActualizado.categoria %></p>
                            <p><i class="bi bi-calendar"></i> <%= ultimoActualizado.fecha %></p>
                        </div>
                        <div class="col-4 text-end">
                            <i class="bi bi-pencil" style="font-size: 5rem; opacity: 0.3;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Fila 3: Gráficos -->
        <div class="row mb-4">
            <!-- Gráfico Circular (Áreas) -->
            <div class="col-md-6">
                <div class="card-dashboard">
                    <h5 class="card-title">
                        <i class="bi bi-pie-chart"></i> Distribución por Área
                    </h5>
                    <div class="chart-container">
                        <canvas id="graficoAreas"></canvas>
                    </div>
                    <div class="row mt-3">
                        <% graficoAreas.forEach((area, index) => { %>
                        <div class="col-6 mb-2">
                            <div class="d-flex align-items-center">
                                <span class="badge bg-primary me-2"><%= area.value %></span>
                                <%= area.label %>
                            </div>
                        </div>
                        <% }); %>
                    </div>
                </div>
            </div>
            <!-- Gráfico de Barras (Categorías) -->
            <div class="col-md-6">
                <div class="card-dashboard">
                    <h5 class="card-title">
                        <i class="bi bi-bar-chart"></i> Empleados por Categoría
                    </h5>
                    <div class="chart-container">
                        <canvas id="graficoCategorias"></canvas>
                    </div>
                    <div class="row mt-3">
                        <% graficoCategorias.forEach((cat, index) => { %>
                        <div class="col-6 mb-2">
                            <div class="d-flex align-items-center">
                                <span class="badge bg-success me-2"><%= cat.value %></span>
                                <%= cat.label %>
                            </div>
                        </div>
                        <% }); %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Fila 4: Estados -->
        <div class="row">
            <div class="col-12">
                <div class="card-dashboard">
                    <h5 class="card-title">
                        <i class="bi bi-table"></i> Distribución por Estado
                    </h5>
                    <div class="row">
                        <% estados.forEach(estado => { %>
                        <div class="col-md-4 mb-3">
                            <div class="card">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="badge badge-estado bg-<%= 
                                            estado.estado === 'Activo' ? 'success' :
                                            estado.estado === 'Vacaciones' ? 'warning' :
                                            estado.estado === 'Inactivo' ? 'danger' :
                                            estado.estado === 'Licencia' ? 'info' :
                                            estado.estado === 'Capacitación' ? 'primary' :
                                            'secondary'
                                        %>">
                                            <%= estado.estado %>
                                        </span>
                                        <h4 class="mb-0"><%= estado.cantidad %></h4>
                                    </div>
                                    <div class="progress">
                                        <div class="progress-bar bg-<%= 
                                            estado.estado === 'Activo' ? 'success' :
                                            estado.estado === 'Vacaciones' ? 'warning' :
                                            estado.estado === 'Inactivo' ? 'danger' :
                                            estado.estado === 'Licencia' ? 'info' :
                                            'secondary'
                                        %>" style="width: <%= estado.porcentaje %>;"></div>
                                    </div>
                                    <p class="text-muted mb-0 text-end"><%= estado.porcentaje %></p>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Gráfico Circular - Áreas
        const ctxAreas = document.getElementById('graficoAreas').getContext('2d');
        new Chart(ctxAreas, {
            type: 'pie',
            data: {
                labels: [<% graficoAreas.forEach(item => { %>'<%= item.label %>', <% }); %>],
                datasets: [{
                    data: [<% graficoAreas.forEach(item => { %><%= item.value %>, <% }); %>],
                    backgroundColor: [
                        '#4e73df', '#1cc88a', '#f6c23e', '#36b9cc', '#e74a3b'
                    ],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'bottom' }
                }
            }
        });

        // Gráfico de Barras - Categorías
        const ctxCategorias = document.getElementById('graficoCategorias').getContext('2d');
        new Chart(ctxCategorias, {
            type: 'bar',
            data: {
                labels: [<% graficoCategorias.forEach(item => { %>'<%= item.label %>', <% }); %>],
                datasets: [{
                    label: 'Cantidad de Empleados',
                    data: [<% graficoCategorias.forEach(item => { %><%= item.value %>, <% }); %>],
                    backgroundColor: '#4e73df',
                    borderRadius: 5
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                        stepSize: 1,
                        grid: { display: true }
                    }
                },
                plugins: {
                    legend: { display: false }
                }
            }
        });
    </script>
</body>
</html>